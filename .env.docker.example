# Copy this file to .env.docker and adjust values for your machine.

# Required: host path containing config.yaml, libraries, and downloaded music.
MUSIC_FERRY_DATA=/home/YOUR_USER/.music-ferry

# Optional: host mount roots for removable devices.
HOST_MEDIA_DIR=/media
HOST_RUN_MEDIA_DIR=/run/media

# Optional: web port and timezone.
MUSIC_FERRY_PORT=4444
TZ=UTC

# Optional: host-side privileged safe-unplug helper (recommended for Docker).
# Example:
# MUSIC_FERRY_UNPLUG_HELPER_URL=http://host.docker.internal:17888
# MUSIC_FERRY_UNPLUG_HELPER_TOKEN=replace-with-random-token
# Helper token is required when helper is enabled.
MUSIC_FERRY_UNPLUG_HELPER_URL=
MUSIC_FERRY_UNPLUG_HELPER_TOKEN=
